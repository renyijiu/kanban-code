{
  "name": "@kanban-code/cli",
  "version": "0.1.0",
  "description": "Kanban Code CLI — inspect cards, sessions, and orchestrate agents",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "bin": {
    "kanban": "./dist/kanban.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx src/kanban.ts",
    "test": "tsx --test --test-force-exit --test-reporter=spec 'src/*.test.ts'"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.16.0",
    "chokidar": "^5.0.0",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.2",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
